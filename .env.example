# Neon Postgres connection string (Project → Connection Details → Pooled connection)
NEON_DATABASE_URL=postgres://USER:PASSWORD@ep-xxx.aws.neon.tech/lattopi?sslmode=require

# Pi Network Developer API key
PI_API_KEY=your_pi_developer_api_key

# Admin gate (used by /admin and admin-* functions). Long random string.
ADMIN_SECRET=change_me_to_a_long_random_string

# Optional: Maileroo transactional emails for winner notifications
MAILEROO_API_KEY=your_maileroo_api_key
